# Async SQLAlchemy URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://admin:adminpassword@localhost:5432/notification_system

CORS_ORIGINS=http://localhost:3000

# Connection pool (align with delivery concurrency, e.g. Semaphore in NotificationService)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

DB_STATEMENT_TIMEOUT_MS=0
NOTIFICATION_DELIVERY_CONCURRENCY=30
